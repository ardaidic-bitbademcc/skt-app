{
  "name": "skt-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/backend",
    "packages/web",
    "packages/mobile"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:web": "npm run dev --workspace=packages/web",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:web\"",
    "build": "npm run build --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
