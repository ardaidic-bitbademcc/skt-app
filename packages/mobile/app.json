{
  "expo": {
    "name": "SKT Takip",
    "slug": "skt-takip",
    "version": "1.0.0",
    "scheme": "skt",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1d4ed8"
    },
    "ios": {
      "bundleIdentifier": "com.skt.takip",
      "infoPlist": {
        "NSCameraUsageDescription": "Barkod okumak için kamera gerekli"
      }
    },
    "android": {
      "package": "com.skt.takip",
      "newArchEnabled": false,
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Barkod okumak için kamera gerekli"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1f60b643-c0d8-4929-8072-c8091358eb3d"
      }
    },
    "owner": "ardaidic"
  }
}
